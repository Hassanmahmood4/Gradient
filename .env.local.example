# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# Clerk — authentication (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — database (Project Settings → API)
# URL is the project URL; the SERVICE ROLE key is secret and server-only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key
